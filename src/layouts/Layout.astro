---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "ClawHouse - Your AI Agent Deserves a Home",
  description = "An iOS app that gives your OpenClaw agent a tiny living room. Watch it work, chat with it, get pinged when it's done. Open source.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://clawhouse.dev");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="keywords" content="ClawHouse, OpenClaw, AI agent, iOS app, agent monitor, living room, open source" />
    <meta name="author" content="Ventuss" />
    <meta name="theme-color" content="#fdfbf7" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Patrick+Hand&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ClawHouse",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "iOS",
      "description": description,
      "url": canonicalURL.toString(),
      "author": {
        "@type": "Person",
        "name": "Ventuss"
      },
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />
  </head>
  <body class="min-h-screen">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-paper/90 backdrop-blur-sm border-b-2 border-dashed border-pencil/20">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-heading text-2xl md:text-3xl text-pencil hover:text-red-marker transition-colors">
          ClawHouse
        </a>
        <div class="flex items-center gap-6">
          <a href="#features" class="hidden md:inline font-body text-lg text-pencil/70 hover:text-pencil wavy-underline transition-colors">Features</a>
          <a href="#how-it-works" class="hidden md:inline font-body text-lg text-pencil/70 hover:text-pencil wavy-underline transition-colors">How it Works</a>
          <a
            href="https://github.com/Ventuss-OvO/ClawHouse"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-lg px-4 py-2 border-2 border-pencil bg-white wobbly-sm shadow-sm hover:shadow-md hover:-translate-y-[2px] transition-all duration-100"
          >
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer is part of each page or could be a component -->
  </body>
</html>
